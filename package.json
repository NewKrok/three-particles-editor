{
  "name": "three-particles-editor",
  "version": "2.8.1",
  "type": "module",
  "private": false,
  "homepage": "https://github.com/NewKrok/three-particles-editor",
  "dependencies": {
    "@material/theme": "^14.0.0",
    "@newkrok/three-particles": "^2.9.0",
    "@newkrok/three-utils": "^2.0.2",
    "prismjs": "^1.30.0",
    "sass": "^1.98.0",
    "sirv-cli": "^3.0.1",
    "svelte-preprocess": "^6.0.3",
    "three": "^0.182.0"
  },
  "scripts": {
    "build": "npm run smui-theme-light && npm run smui-theme-dark && rollup -c",
    "dev": "rollup -c -w",
    "start": "sirv public --no-clear",
    "prepare": "husky",
    "smui-theme-light": "node scripts/compile-theme.js public/build/static/smui.css src/theme",
    "smui-theme-dark": "node scripts/compile-theme.js public/build/static/smui-dark.css src/theme --dark",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,svelte}\"",
    "test": "jest",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@smui/button": "^8.0.3",
    "@smui/card": "^8.0.3",
    "@smui/dialog": "^8.0.3",
    "@smui/list": "^8.0.3",
    "@smui/paper": "^8.0.3",
    "@smui/snackbar": "^8.0.3",
    "@smui/tab": "^8.0.3",
    "@smui/tab-bar": "^8.0.3",
    "@smui/textfield": "^8.0.3",
    "@types/jest": "^30.0.0",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "rollup": "^4.60.0",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-svelte": "^7.2.3",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "smui-theme": "^8.0.3",
    "svelte": "^5.55.0",
    "svelte-eslint-parser": "^1.6.0",
    "svrollbar": "^0.12.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
